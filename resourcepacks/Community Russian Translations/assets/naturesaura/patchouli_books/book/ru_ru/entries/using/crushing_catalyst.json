  "pages": [
    {
      "type": "text",
      "text": "$(l:using/altar)Природный Алтарь$() может быть полезен для наполнения некоторых предметов силой $(aura), но его также можно использовать для $(thing)измельчения$() определённых предметов в различные формы.$(br)Этого можно достичь, создав $(item)Разрушающийся Катализатор$() и поместив его на любой из четырёх нижних блоков $(item)Золотого Каменного Кирпича$() вокруг алтаря, а затем поместив ингредиент на алтарь как обычно."
    },
    {
      "type": "naturesaura:tree_ritual",
      "text": "Создание $(item)Разрушающегося Катализатора$() с помощью $(l:practices/tree_ritual)Ритуала Леса$().",
      "recipe": "naturesaura:crushing_catalyst"
    },
    {
      "type": "naturesaura:altar",
      "text": "Создание $(item)Костной Муки$() путём измельчения $(item)Костей$()",
