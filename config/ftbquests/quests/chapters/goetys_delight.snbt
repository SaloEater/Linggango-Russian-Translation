				""
				"{@pagebreak}"
				"\"A warm candy bag.\""
				"\"Speaking of beauty.\""
				"\"A soft candy bag.\""
				"\"Pouring out hope.\""
				"\"A round candy bag.\""
				"\"Calling out longing.\""
				"\"Adorable candy bag.\""
				"\"You are out of place.\""
				"\"Because of what this gaze sees.\""
				"\"All that is rotting and disemboweling.\""
				"\"You say?\""
				"\"I am covered in dust.\""
				"\"A person stained by the mud on the road.\""
				"\"How could such a creation exist?\""
				"\"A soul riddled with holes.\""
				"\"What has been shaped.\""
				"\"Should be unbearable to look at.\""
				"\"Should be screams and cries of agony.\""
				"\"Isn't it?\""
				"\"No.\""
				"\"That rotten human heart.\""
				"\"Forced to abandon the past.\""
				"\"But it is forever.\""
				"\"It must remain in the heart.\""
				"\"Keep a place of fervent longing.\""
				"\"Though I have always, from beginning to end.\""
				"\"I will walk this path.\""
			]
