			title: "<shadow><grad from=#D400D4 to=#D400D4><pulse base=0.5 a=1.0 f=1.5><wave a=0.5 f=0.8 w=0.5>Stegonaut</wave></pulse></grad></shadow>"
			x: 9.0d
