		}
		{
			dependencies: ["19237C5BA8DDB6AF"]
			description: ["<grad from=#787878 to=#787878><shadow a=0.3>Explorer's Compass</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> functions similarly but tracks </grad></shadow><grad from=#787878 to=#787878><shadow a=0.3>structures</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> instead of </grad></shadow><grad from=#50FF1F to=#50FF1F><shadow a=0.3>biomes</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>. You can search for any </grad></shadow><grad from=#50FF1F to=#50FF1F><shadow a=0.3>biome</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> in the game through its menu, and it will display the </grad></shadow><grad from=#CC0000 to=#D64242 f=0.8><shadow a=0.3>distance</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> and point you toward the closest </grad></shadow><grad from=#CC0000 to=#D64242 f=0.8><shadow a=0.3>coordinates</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>.</grad></shadow>"]
			id: "4C373F050CB18168"
