		{
			dependencies: ["19237C5BA8DDB6AF"]
			description: ["<grad from=#787878 to=#787878><shadow a=0.3>Explorer's Compass</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> allows you to </grad></shadow><grad from=#FCE938 to=#FFF6A6 f=0.8><shadow a=0.3>locate</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> any structure in the </grad></shadow><grad from=#6DE32D to=#BDDEAB f=0.8><shadow a=0.3>world</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>. Instead of pointing toward </grad></shadow><grad from=#6DE32D to=#BDDEAB f=0.8><shadow a=0.3>spawn</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>, you can select a specific </grad></shadow><grad from=#787878 to=#787878><shadow a=0.3>structure type</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> from its interface, and the needle will guide you directly to the nearest one.</grad></shadow>"]
