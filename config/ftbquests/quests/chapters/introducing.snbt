			y: -6.0d
		}
		{
			dependencies: ["19237C5BA8DDB6AF"]
			description: [
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Parties allow you to team up with friends in </grad></shadow><grad from=#FF91F0 to=#C470B9 f=0.8><shadow a=0.3>multiplayer</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> to complete </grad></shadow><grad from=#FCE938 to=#FFF6A6 f=0.8><shadow a=0.3>quests</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> together and share your progress. You can find the party management icon in the top corner of your inventory screen.</grad></shadow>"
				"[gap=5]"
				"---"
				"[gap=5]"
				"<shadow a=0.3><grad from=#FF9E1F to=#FF9E1F f=0.6>1. Open the Teams Menu</grad></shadow>"
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Open your inventory and click on the Teams icon.</grad></shadow>"
				"{image:customtextures:textures/team1.png width:300 height:150 align:center}"
				"[gap=5]"
				"---"
				"[gap=5]"
				"<shadow a=0.3><grad from=#FF9E1F to=#FF9E1F f=0.6>2. Create Your Party</grad></shadow>"
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Click the button to start a new party group.</grad></shadow>"
				"{image:customtextures:textures/team2.png width:300 height:140 align:center}"
				"[gap=5]"
				"---"
				"[gap=5]"
				"<shadow a=0.3><grad from=#FF9E1F to=#FF9E1F f=0.6>3. Set a Name and Description</grad></shadow>"
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Enter a custom name and a short description for your party.</grad></shadow>"
				"{image:customtextures:textures/team3.png width:300 height:200 align:center}"
				"[gap=5]"
				"---"
				"[gap=5]"
				"<shadow a=0.3><grad from=#FF9E1F to=#FF9E1F f=0.6>4. Invite Your Friends</grad></shadow>"
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Use the player list to send invites to your friends on the server.</grad></shadow>"
			]
			icon: {
				Count: 1
				id: "ftbquests:custom_icon"
				tag: {
					Icon: "ftblibrary:icons/friends"
				}
			}
			id: "7A545E5DF48EDB9B"
			min_width: 300
			rewards: [{
				id: "7020621638373894"
