		{
			dependencies: ["19237C5BA8DDB6AF"]
			description: [
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>Amulets provide </grad></shadow><grad from=#D126D1 to=#D18AD1 f=0.8><shadow a=0.3>unique buffs</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> at completely no cost. You will receive them right at the start of the </grad></shadow><grad from=#6DE32D to=#BDDEAB f=0.8><shadow a=0.3>world</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>, giving you a helpful boost for </grad></shadow><grad from=#6DE32D to=#BDDEAB f=0.8><shadow a=0.3>early-game survival</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> and progression.</grad></shadow>"
				""
				"<shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>While they are great for getting your footing early on, they are strictly designed to </grad></shadow><grad from=#6DE32D to=#BDDEAB f=0.8><shadow a=0.3>help</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7> you get started. Do not expect them to carry you all the way into the </grad></shadow><grad from=#CC0000 to=#BF8080 f=0.8><shadow a=0.3>late game</shadow></grad><shadow a=0.3><grad from=#FFFFFF to=#C7C7C7>.</grad></shadow>"
			]
			id: "55A0C32438274E54"
			rewards: [{
				id: "4C93D1BB579BFD27"
